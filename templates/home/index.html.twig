{% extends 'base.html.twig' %}

{% block title %}Inass - Portfolio{% endblock %}

{% block body %}
    {# l'aceuille #}
    <div class="intro-container">
        <div style="margin-bottom: 30px;">
           {# On change .jpeg par .png ici #}
        <span class="intro-text">Bonjour! je suis</span>
        <h1>Inass</h1>
        <span class="intro-text" style="color: var(--rose-vif); opacity: 1;">Etudiante en Réseaux et Télécommunications </span>
        
        <p style="color: var(--rose-medium); font-size: 1.1rem; max-width: 800px; margin: 40px auto; line-height: 1.8; font-weight: 300;">
           Bonjour, je m'appelle Inass Atouil. Je suis étudiante en première année de BUT Réseaux et Télécommunications à l'IUT de Roanne. Je fais partie du groupe A2 et je vous souhaite la bienvenue sur mon site web.
    </div>

    {# navigation rapide le bulles dcp #}
    <div class="bubble-container">
        <a href="{{ path('app_competences') }}" class="bubble">Mes compétences</a>
        <a href="{{ path('app_cv') }}" class="bubble">Mon CV</a>
        <a href="{{ path('app_contact') }}" class="bubble">Contactez moi</a>
    </div>  
    <div class="intro-container" style="margin-top: 60px;">
        <span class="intro-text" style="font-size: 0.8rem; letter-spacing: 5px;">Centres d'intérêt</span>
        <div class="bubble-container" style="padding-top: 20px;">
            <div class="bubble" style="font-size: 0.9rem; padding: 15px 25px;">Design UX/UI</div>
            <div class="bubble" style="font-size: 0.9rem; padding: 15px 25px;">Cybersecurité</div>
            <div class="bubble" style="font-size: 0.9rem; padding: 15px 25px;">Recherche en IA</div>
        </div>
    </div>

    <div class="intro-container" style="border: 1px solid var(--rose-light); padding: 40px; border-radius: 30px; margin-top: 50px; background: rgba(243, 213, 217, 0.05);">
    <h2 style="color: var(--rose-light);">En savoir plus sur moi</h2>
    <p style="opacity: 0.8; margin-bottom: 30px;">Découvrez mes passions, mes projets personnels et ce qui me motive chaque jour.</p>
    <a href="{{ path('app_about_more') }}" class="bubble" style="background: var(--rose-vif);">Cliquez ici</a>
</div>

    <div style="text-align: center; margin: 80px auto; max-width: 600px;">
        <p style="color: var(--rose-light); font-size: 1.4rem; font-style: italic; opacity: 0.8;">
            
        </p>
    </div>

   {#bas de la page#}
    <div style="text-align: center; margin-top: 100px; padding: 50px; background: rgba(0,0,0,0.2); border-radius: 50px 50px 0 0;">
        <a href="{{ path('app_contact') }}" class="bubble" style="background: var(--rose-vif); color: white;">LET'S TALK</a>
        <p style="margin-top: 40px; font-size: 0.7rem; opacity: 0.5; letter-spacing: 2px;">© 2026 Inass - Réalisé avec SYMFONY</p>
    </div>
{% endblock %}
